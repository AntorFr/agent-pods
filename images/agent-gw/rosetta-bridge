#!/usr/bin/env python3
# Identical copy in images/agent-gw/rosetta-bridge — keep both in sync (the
# docker build context is images/<name>, so the file cannot be shared).
"""rosetta-bridge — stdio-to-HTTP MCP relay with OAuth token refresh.

Claude Code only supports static headers for HTTP MCP servers, but rosetta
(the MCP hub) wants short-lived OAuth access tokens. This bridge closes the
gap: Claude talks newline-delimited JSON-RPC on stdio (as with any local MCP
server), the bridge forwards every message to the hub over HTTPS and handles
the token lifecycle itself: fetched via client_credentials, kept in memory
only, renewed before expiry, one retry on 401.

Standard library only, on purpose: it must run on the bare python3 of every
agent body image, with zero dependency to keep in sync.

Usage:  rosetta-bridge <addon>          (e.g. rosetta-bridge maps)

Env:
  AGENT_CLIENT_ID / AGENT_CLIENT_SECRET  machine identity (Authelia client)
  ROSETTA_URL        default https://rosetta.mcp.berard.me
  ROSETTA_TOKEN_URL  default https://auth.berard.me/api/oidc/token
  ROSETTA_SCOPE      default mcp
"""

import base64
import json
import os
import sys
import threading
import time
import urllib.error
import urllib.request

TIMEOUT = 60.0  # generous: some upstream tools wait on slow provider APIs


class TokenManager:
    """Serves a valid bearer token, refreshing it under a lock when stale."""

    def __init__(self):
        self.url = os.environ.get("ROSETTA_TOKEN_URL", "https://auth.berard.me/api/oidc/token")
        self.client_id = os.environ.get("AGENT_CLIENT_ID", "")
        self.client_secret = os.environ.get("AGENT_CLIENT_SECRET", "")
        self.scope = os.environ.get("ROSETTA_SCOPE", "mcp")
        self._lock = threading.Lock()
        self._token = ""
        self._expiry = 0.0

    def get(self, force: bool = False) -> str:
        with self._lock:
            if force or not self._token or time.time() >= self._expiry:
                self._refresh()
            return self._token

    def _refresh(self) -> None:
        basic = base64.b64encode(f"{self.client_id}:{self.client_secret}".encode()).decode()
        req = urllib.request.Request(
            self.url,
            data=f"grant_type=client_credentials&scope={self.scope}".encode(),
            headers={
                "Authorization": f"Basic {basic}",
                "Content-Type": "application/x-www-form-urlencoded",
            },
        )
        with urllib.request.urlopen(req, timeout=30) as resp:
            payload = json.load(resp)
        self._token = payload["access_token"]
        # Renew one minute early so an in-flight call never carries a dying token.
        self._expiry = time.time() + max(int(payload.get("expires_in", 3600)) - 60, 60)


def parse_http_response(resp) -> list:
    """One HTTP response -> JSON-RPC messages (plain JSON or SSE data lines)."""
    body = resp.read().decode("utf-8", "replace")
    if not body.strip():
        return []  # 202 Accepted: notification acknowledged, nothing to relay
    if "text/event-stream" in resp.headers.get("Content-Type", ""):
        return [json.loads(line[5:]) for line in body.splitlines() if line.startswith("data:")]
    return [json.loads(body)]


def relay(message: dict, endpoint: str, tokens: TokenManager, out_lock: threading.Lock) -> None:
    data = json.dumps(message).encode()

    def post(token: str):
        req = urllib.request.Request(
            endpoint,
            data=data,
            headers={
                "Authorization": f"Bearer {token}",
                "Content-Type": "application/json",
                "Accept": "application/json, text/event-stream",
            },
        )
        return urllib.request.urlopen(req, timeout=TIMEOUT)

    try:
        try:
            resp = post(tokens.get())
        except urllib.error.HTTPError as exc:
            if exc.code != 401:
                raise
            resp = post(tokens.get(force=True))  # stale token: refresh once, retry
        with resp:
            replies = parse_http_response(resp)
    except Exception as exc:  # network, auth, hub down... fail the call, not the bridge
        if "id" not in message:
            print(f"rosetta-bridge: dropped notification: {exc}", file=sys.stderr, flush=True)
            return
        replies = [{
            "jsonrpc": "2.0",
            "id": message["id"],
            "error": {"code": -32000, "message": f"rosetta-bridge: {type(exc).__name__}: {exc}"},
        }]

    with out_lock:
        for reply in replies:
            sys.stdout.write(json.dumps(reply) + "\n")
        sys.stdout.flush()


def main() -> int:
    if len(sys.argv) != 2:
        print("usage: rosetta-bridge <addon>", file=sys.stderr)
        return 2
    base = os.environ.get("ROSETTA_URL", "https://rosetta.mcp.berard.me").rstrip("/")
    endpoint = f"{base}/{sys.argv[1]}/"
    tokens = TokenManager()
    out_lock = threading.Lock()

    # One thread per request: a slow upstream call must not block the next one.
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            message = json.loads(line)
        except json.JSONDecodeError as exc:
            print(f"rosetta-bridge: bad JSON from client: {exc}", file=sys.stderr, flush=True)
            continue
        threading.Thread(
            target=relay, args=(message, endpoint, tokens, out_lock), daemon=True
        ).start()
    return 0


if __name__ == "__main__":
    sys.exit(main())
